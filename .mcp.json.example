{
  "mcpServers": {
    "editor": {
      "type": "sse",
      "url": "http://localhost:8098/sse"
    },
    "api": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "sbox-api-mcp"],
      "env": {
        "SBOX_API_URL": "https://cdn.sbox.game/releases/2026-04-02-21-06-53.zip.json"
      }
    },
    "docs": {
      "command": "node",
      "args": ["path/to/sbox-docs-mcp/dist/index.js"]
    }
  }
}
